{
  "name": "Workspace",
  "type": "object",
  "properties": {
    "owner_user_id": {
      "type": "string",
      "title": "Owner User ID"
    },
    "name": {
      "type": "string",
      "title": "Workspace Name"
    },
    "onboarding_complete": {
      "type": "boolean",
      "title": "Onboarding Complete",
      "default": false
    },
    "gmail_connected": {
      "type": "boolean",
      "title": "Gmail Connected",
      "default": false
    },
    "gmail_access_token": {
      "type": "string",
      "title": "Gmail Access Token"
    },
    "gmail_refresh_token": {
      "type": "string",
      "title": "Gmail Refresh Token"
    },
    "gmail_token_expiry": {
      "type": "number",
      "title": "Gmail Token Expiry (Unix timestamp)"
    },
    "gmail_email": {
      "type": "string",
      "title": "Connected Gmail Address"
    },
    "ai_provider": {
      "type": "string",
      "title": "AI Provider",
      "enum": [
        "openai",
        "anthropic",
        "base44"
      ],
      "default": "base44"
    },
    "ai_api_key": {
      "type": "string",
      "title": "AI API Key"
    },
    "ai_model": {
      "type": "string",
      "title": "AI Model",
      "default": "gpt-4o"
    },
    "plan": {
      "type": "string",
      "title": "Plan",
      "enum": [
        "free",
        "starter",
        "pro"
      ],
      "default": "free"
    },
    "monthly_email_limit": {
      "type": "number",
      "title": "Monthly Email Limit",
      "default": 100
    },
    "sync_lock": {
      "type": "boolean",
      "title": "Sync Lock",
      "default": false
    },
    "support_email": {
      "type": "string",
      "title": "Support Contact Email",
      "description": "Displayed to users as the support contact. Required before publishing as a template."
    },
    "support_url": {
      "type": "string",
      "title": "Support / Help URL",
      "description": "Optional help center or docs URL shown alongside support email."
    }
  },
  "required": [
    "owner_user_id",
    "name"
  ],
  "rls": {
    "create": {
      "owner_user_id": "{{user.id}}"
    },
    "read": {
      "owner_user_id": "{{user.id}}"
    },
    "update": {
      "owner_user_id": "{{user.id}}"
    },
    "delete": {
      "owner_user_id": "{{user.id}}"
    }
  }
}